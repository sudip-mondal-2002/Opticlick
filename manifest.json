{
  "manifest_version": 3,
  "name": "Opticlick Engine",
  "version": "1.0.0",
  "description": "Autonomous web agent using Set-of-Mark visual prompting and Gemini 3.1 Pro.",

  "permissions": [
    "activeTab",
    "scripting",
    "debugger",
    "storage"
  ],

  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/annotator.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Opticlick Engine"
  },

  "host_permissions": [
    "<all_urls>"
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
