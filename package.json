{
  "name": "opticlick-engine",
  "version": "1.0.1",
  "description": "Autonomous web agent using Set-of-Mark visual prompting with Gemini, Claude, OpenAI, and Ollama models",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "postinstall": "wxt prepare",
    "test": "vitest run --project unit --project integration --project dom --project e2e",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:dom": "vitest run --project dom",
    "test:watch": "vitest --project unit --project integration --project dom",
    "test:coverage": "vitest run --project unit --project integration --project dom --project e2e --coverage",
    "test:e2e": "vitest run --project e2e",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.38",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/langgraph": "^1.2.7",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.4.4",
    "@tailwindcss/vite": "^4.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/chrome": "^0.1.39",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^15.15.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.2.4",
    "wxt": "^0.20.20"
  }
}
